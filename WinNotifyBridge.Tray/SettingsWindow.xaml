<Window x:Class="WinNotifyBridge.Tray.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinNotifyBridge Settings"
        Height="460"
        Width="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,8,12,0" VerticalAlignment="Top" Text="Telegram Bot Token" />
        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,4,0,0" Text="{Binding BotToken, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,12,0" VerticalAlignment="Top" Text="Telegram Chat ID" />
        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4,0,0" Text="{Binding ChatId, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,12,0" VerticalAlignment="Top" Text="Bridge URL prefix" />
        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,4,0,0" Text="{Binding BridgePrefix, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,12,0" VerticalAlignment="Top" Text="Allowed apps" />
        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,4,0,0"
                 Height="140"
                 VerticalScrollBarVisibility="Auto"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Text="{Binding AllowedApps, UpdateSourceTrigger=PropertyChanged}" />

        <CheckBox Grid.Row="4" Grid.Column="1"
                  Margin="0,10,0,0"
                  Content="Enable Windows Event Log watcher"
                  IsChecked="{Binding EnableEventLogWatcher}" />

        <TextBlock Grid.Row="5" Grid.Column="1"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Foreground="DimGray"
                   Text="Allowed apps accepts names separated by comma, semicolon, or new lines (e.g. Teams, Outlook, Windows Security). Empty means allow all apps." />

        <StackPanel Grid.Row="6" Grid.Column="1"
                    Margin="0,14,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Margin="0,0,8,0"
                    Padding="14,4"
                    Content="Save"
                    Command="{Binding SaveCommand}" />
            <Button Margin="0,0,8,0"
                    Padding="14,4"
                    Content="Save + Restart service"
                    Command="{Binding SaveAndRestartCommand}" />
            <Button Padding="14,4"
                    Content="Cancel"
                    Command="{Binding CancelCommand}" />
        </StackPanel>
    </Grid>
</Window>
