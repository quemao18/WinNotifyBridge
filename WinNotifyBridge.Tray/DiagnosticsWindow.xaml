<Window x:Class="WinNotifyBridge.Tray.DiagnosticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinNotifyBridge Diagnostics Monitor"
        Height="560"
        Width="1140"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Width="90" Margin="0,0,8,0" Content="Refresh" Click="RefreshClick" />
            <CheckBox x:Name="AutoRefreshCheckBox" VerticalAlignment="Center" IsChecked="True" Content="Auto refresh (3s)" Checked="AutoRefreshChanged" Unchecked="AutoRefreshChanged" />
            <TextBlock x:Name="StatusTextBlock" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="DimGray" Text="Waiting for data..." />
        </StackPanel>

        <TabControl>
            <TabItem Header="Event Viewer">
                <DataGrid x:Name="EventsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#FFF7F7F7">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding TimeLocal}" Width="170" />
                        <DataGridTextColumn Header="Id" Binding="{Binding EventId}" Width="70" />
                        <DataGridTextColumn Header="Provider" Binding="{Binding ProviderName}" Width="220" />
                        <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="WPN Database">
                <DataGrid x:Name="WpnGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#FFF7F7F7">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Arrival" Binding="{Binding ArrivalLocal}" Width="165" />
                        <DataGridTextColumn Header="Type" Binding="{Binding NotificationType}" Width="70" />
                        <DataGridTextColumn Header="AppModelId" Binding="{Binding AppModelId}" Width="220" />
                        <DataGridTextColumn Header="DisplayName" Binding="{Binding DisplayName}" Width="170" />
                        <DataGridTextColumn Header="App" Binding="{Binding App}" Width="140" />
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="180" />
                        <DataGridTextColumn Header="Body" Binding="{Binding Body}" Width="220" />
                        <DataGridTextColumn Header="Raw" Binding="{Binding RawPreview}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
